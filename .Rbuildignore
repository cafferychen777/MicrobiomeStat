# IDE and local tooling
^\.Rproj\.user$
^\.Rproj\.user/.*$
^.*\.Rproj$
^\.github$
^\.github/.*$
^\.claude$
^\.claude/.*$
^CLAUDE\.md$

# Local dependency/bootstrap tooling
^renv$
^renv/.*$
^renv\.lock$

# Developer-only scripts and benchmarks
^dev$
^dev/.*$

# Generated website and vignette artifacts
^_pkgdown\.yml$
^pkgdown$
^pkgdown/.*$
^docs$
^docs/.*$
^vignettes/.*\.html$
^vignettes/.*\.pdf$
^vignettes/.*_files$
^vignettes/.*_cache$
^\.nojekyll$

# README sources and release metadata
^README-CN\.Rmd$
^README-CN\.md$
^README-ES\.Rmd$
^README-ES\.md$
^README\.Rmd$
^LICENSE\.md$
^cran-comments\.md$
^CRAN-RELEASE$
^revdep$
^revdep/.*$
^\.travis\.yml$
^codecov\.yml$

# Local notes and ad hoc files
^TODO_BUGFIXES\.md$

# Research-only local data not shipped with the package
^data/ecam_full($|/)
^data/yassour2018_.*\.rds$
